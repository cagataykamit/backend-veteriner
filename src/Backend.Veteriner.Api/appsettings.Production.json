{
  "ConnectionStrings": {
    "SqlServer": "Server=localhost;Database=VeterinerDb;User Id=Backend_Veteriner_User;Password=;TrustServerCertificate=True"
  },

  "Jwt": {
    "Issuer": "Backend.Veteriner",
    "Audience": "Backend.Veteriner.Production.Audience",
    "Key": "",
    "ExpMinutes": 60,
    "RefreshExpDays": 7
  },

  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "EnableSsl": true,
    "UseStartTls": true,
    "User": "",
    "Pass": "",
    "From": "no-reply@example.com"
  },

  "Outbox": {
    "MaxRetryCount": 10,
    "BaseDelaySeconds": 5,
    "BatchSize": 50,
    "LoopIntervalSeconds": 5
  },

  "Mail": {
    "ContactTo": "",
    "HrTo": ""
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/backend-veteriner/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "PermissionChange": {
    "RevokeSessionsOnPermissionChange": false
  },

  "App": {
    "BaseUrl": ""
  },

  "AllowedHosts": "*"
}
