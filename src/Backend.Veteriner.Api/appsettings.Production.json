{
  "ConnectionStrings": {
    "SqlServer": "Server=localhost;Database=VeterinerDb;User Id=Backend_Veteriner_User;Password=;TrustServerCertificate=True"
  },

  "Jwt": {
    "Issuer": "Backend.Veteriner",
    "Audience": "Backend.Veteriner.Production.Audience",
    "Key": "",
    "ExpMinutes": 60,
    "RefreshExpDays": 7
  },

  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "EnableSsl": true,
    "UseStartTls": true,
    "User": "",
    "Pass": "",
    "From": "no-reply@example.com"
  },

  "Outbox": {
    "MaxRetryCount": 10,
    "BaseDelaySeconds": 5,
    "BatchSize": 50,
    "LoopIntervalSeconds": 5
  },

  "RefreshTokenCleanup": {
    "Enabled": true,
    "InitialDelaySeconds": 300,
    "IntervalMinutes": 360,
    "RetentionDays": 30,
    "BatchSize": 2000
  },

  "Mail": {
    "ContactTo": "",
    "HrTo": ""
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "LuckyPennySoftware.MediatR.License": "Fatal",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/backend-veteriner/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "LuckyPennySoftware.MediatR.License": "None"
    }
  },

  "PermissionChange": {
    "RevokeSessionsOnPermissionChange": false
  },

  "App": {
    "BaseUrl": ""
  },

  "Billing": {
    "DefaultCheckoutProvider": "Iyzico",
    "Stripe": {
      "SecretKey": "",
      "WebhookSecret": "",
      "SuccessUrl": "",
      "CancelUrl": "",
      "SubscriptionPriceIds": {
        "Basic": "",
        "Pro": "",
        "Premium": ""
      }
    },
    "Iyzico": {
      "ApiKey": "",
      "SecretKey": "",
      "MerchantId": "",
      "BaseUrl": "https://api.iyzipay.com",
      "CallbackUrl": "",
      "ReturnSuccessUrl": "",
      "ReturnFailureUrl": "",
      "PlanPricesTry": {
        "Basic": 0,
        "Pro": 0,
        "Premium": 0
      },
      "WebhookSecret": "",
      "AllowUnsignedSandboxWebhooks": false,
      "Locale": "tr",
      "Country": "Turkey",
      "City": "Istanbul",
      "SandboxBuyerIp": ""
    }
  },

  "AllowedHosts": "*"
}
