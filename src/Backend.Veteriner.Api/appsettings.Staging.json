{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "QueryConnection": ""
  },

  "AppointmentProjection": {
    "Enabled": true,
    "BatchSize": 50,
    "LoopIntervalSeconds": 2,
    "ConsumerName": "appointment-read-model-v1",
    "ClaimingEnabled": false,
    "LeaseDurationSeconds": 60,
    "ClaimBatchSize": 1
  },

  "AppointmentProjectionHealth": {
    "DegradedAfterSeconds": 10,
    "UnhealthyAfterSeconds": 60,
    "DeadLetterIsUnhealthy": true
  },

  "ClientProjectionHealth": {
    "DegradedAfterSeconds": 10,
    "UnhealthyAfterSeconds": 60,
    "DeadLetterIsUnhealthy": true
  },

  "PetProjectionHealth": {
    "DegradedAfterSeconds": 10,
    "UnhealthyAfterSeconds": 60,
    "DeadLetterIsUnhealthy": true
  },

  "QueryReadModels": {
    "AppointmentsEnabled": false,
    "DashboardAppointmentsEnabled": false,
    "ClientsEnabled": false,
    "PetsEnabled": false,
    "SharedSearchLookupEnabled": false,
    "PaymentsSearchLookupEnabled": false
  },

  "RateLimiting": {
    "Enabled": true
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "LuckyPennySoftware.MediatR.License": "Fatal",
        "System": "Warning"
      }
    }
  }
}
