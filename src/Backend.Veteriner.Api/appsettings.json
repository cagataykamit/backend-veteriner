{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Jwt": {
    "Issuer": "Backend.Veteriner",
    "Audience": "Backend.Veteriner.Audience",
    "Key": "",
    "ExpMinutes": 60,
    "RefreshExpDays": 7
  },

  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": false,
    "UseStartTls": true,
    "User": "",
    "Pass": "",
    "From": "no-reply@example.com"
  },

  "Outbox": {
    "MaxRetryCount": 8,
    "BaseDelaySeconds": 5,
    "BatchSize": 50,
    "LoopIntervalSeconds": 5
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.ndjson",
          "rollingInterval": "Day",
          "shared": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithExceptionDetails" ],
    "Properties": { "Application": "Backend.Veteriner.Api" }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "App": {
    "BaseUrl": "https://localhost:5001"
  },

  "Session": {
    "SingleSessionPerUser": false
  },

  "Billing": {
    "DefaultCheckoutProvider": "Manual",
    "ScheduledPlanChangeProcessor": {
      "Enabled": true,
      "IntervalSeconds": 60,
      "BatchSize": 100
    },
    "Stripe": {
      "SecretKey": "",
      "WebhookSecret": "",
      "SuccessUrl": "",
      "CancelUrl": "",
      "SubscriptionPriceIds": {
        "Basic": "",
        "Pro": "",
        "Premium": ""
      }
    },
    "Iyzico": {
      "ApiKey": "",
      "SecretKey": "",
      "MerchantId": "",
      "BaseUrl": "",
      "CallbackUrl": "",
      "ReturnSuccessUrl": "",
      "ReturnFailureUrl": "",
      "PlanPricesTry": {
        "Basic": 0,
        "Pro": 0,
        "Premium": 0
      },
      "WebhookSecret": "",
      "AllowUnsignedSandboxWebhooks": false,
      "Locale": "tr",
      "Country": "Turkey",
      "City": "Istanbul"
    }
  },

  "AllowedHosts": "*"
}
