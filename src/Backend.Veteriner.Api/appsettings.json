{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "QueryConnection": ""
  },

  "Jwt": {
    "Issuer": "Backend.Veteriner",
    "Audience": "Backend.Veteriner.Audience",
    "Key": "",
    "ExpMinutes": 60,
    "RefreshExpDays": 7
  },

  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": false,
    "UseStartTls": true,
    "User": "",
    "Pass": "",
    "From": "no-reply@example.com"
  },

  "Outbox": {
    "Enabled": true,
    "MaxRetryCount": 8,
    "BaseDelaySeconds": 5,
    "BatchSize": 50,
    "LoopIntervalSeconds": 5
  },

  "AppointmentProjection": {
    "Enabled": true,
    "BatchSize": 50,
    "LoopIntervalSeconds": 2,
    "ConsumerName": "appointment-read-model-v1",
    "ClaimingEnabled": false,
    "LeaseDurationSeconds": 60,
    "ClaimBatchSize": 1
  },

  "AppointmentProjectionHealth": {
    "DegradedAfterSeconds": 10,
    "UnhealthyAfterSeconds": 30,
    "DeadLetterIsUnhealthy": true
  },

  "ClientProjectionHealth": {
    "DegradedAfterSeconds": 10,
    "UnhealthyAfterSeconds": 30,
    "DeadLetterIsUnhealthy": true
  },

  "PetProjectionHealth": {
    "DegradedAfterSeconds": 10,
    "UnhealthyAfterSeconds": 30,
    "DeadLetterIsUnhealthy": true
  },

  "PetProjection": {
    "Enabled": false,
    "BatchSize": 50,
    "LoopIntervalSeconds": 2,
    "ConsumerName": "pet-read-model-v1"
  },

  "AppointmentProjectionMonitoring": {
    "WarningPendingAgeSeconds": 10,
    "CriticalPendingAgeSeconds": 30,
    "ParityCheckEnabled": false,
    "ParityCheckIntervalSeconds": 300
  },

  "QueryReadModels": {
    "AppointmentsEnabled": false,
    "DashboardAppointmentsEnabled": false,
    "ClientsEnabled": false,
    "PetsEnabled": false,
    "SharedSearchLookupEnabled": false
  },

  "RefreshTokenCleanup": {
    "Enabled": false,
    "InitialDelaySeconds": 300,
    "IntervalMinutes": 360,
    "RetentionDays": 30,
    "BatchSize": 2000
  },

  "Reminders": {
    "Processor": {
      "Enabled": true,
      "IntervalMinutes": 5,
      "BatchSize": 100,
      "WindowToleranceMinutes": 10
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "LuckyPennySoftware.MediatR.License": "Fatal",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.ndjson",
          "rollingInterval": "Day",
          "shared": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithExceptionDetails" ],
    "Properties": { "Application": "Backend.Veteriner.Api" }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "LuckyPennySoftware.MediatR.License": "None"
    }
  },

  "App": {
    "BaseUrl": "https://localhost:5001"
  },

  "Session": {
    "SingleSessionPerUser": false
  },

  "Billing": {
    "DefaultCheckoutProvider": "Manual",
    "ScheduledPlanChangeProcessor": {
      "Enabled": true,
      "IntervalSeconds": 60,
      "BatchSize": 100
    },
    "Stripe": {
      "SecretKey": "",
      "WebhookSecret": "",
      "SuccessUrl": "",
      "CancelUrl": "",
      "SubscriptionPriceIds": {
        "Basic": "",
        "Pro": "",
        "Premium": ""
      }
    },
    "Iyzico": {
      "ApiKey": "",
      "SecretKey": "",
      "MerchantId": "",
      "BaseUrl": "",
      "CallbackUrl": "",
      "ReturnSuccessUrl": "",
      "ReturnFailureUrl": "",
      "PlanPricesTry": {
        "Basic": 0,
        "Pro": 0,
        "Premium": 0
      },
      "WebhookSecret": "",
      "AllowUnsignedSandboxWebhooks": false,
      "Locale": "tr",
      "Country": "Turkey",
      "City": "Istanbul",
      "SandboxBuyerIp": ""
    }
  },

  "RateLimiting": {
    "GlobalPermitLimit": 200
  },

  "PerformanceDiagnostics": {
    "Enabled": true,
    "SlowSqlMs": 200,
    "SlowConnectionOpenMs": 1000,
    "MediatRSlowMs": 400,
    "CriticalHandlerTotalMsWarning": 400,
    "CriticalHandlerSlowStepMsWarning": 150,
    "HttpRequestWarningMs": 750
  },

  "AllowedHosts": "*"
}
